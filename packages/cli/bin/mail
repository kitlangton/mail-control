#!/usr/bin/env bun
import { NodeRuntime } from "@effect/platform-node"

const metaFlags = new Set(["--help", "-h", "--version", "--completions", "--wizard"])
const requestingHelpOnly = process.argv.length <= 2 || process.argv.some((arg) => metaFlags.has(arg))

if (requestingHelpOnly && process.env.GOOGLE_CLIENT_SECRET_PATH === undefined) {
  process.env.GOOGLE_CLIENT_SECRET_PATH = "__placeholder__"
}

const { program } = await import("../src/cli.ts")

NodeRuntime.runMain(program)
